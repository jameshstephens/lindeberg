        (forall i : Fin n, IndepFun (fun ω => (Y ω i) ^ 2) (D2 i) μ) :=
    y_frozen_derivative_indepFun_of_indep_frozen
      (Ω := Ω) (mΩ := mΩ) (μ := μ) (X := X) (Y := Y)
