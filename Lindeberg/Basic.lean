    (hIntInterp : forall k : Nat, k <= n ->
      Integrable (fun ω => f (lindebergInterpolate X Y k ω)) μ)
    (hd1𝓕 : forall i : Fin n, StronglyMeasurable[𝓕 i] (D1 i))
    (hd2𝓕 : forall i : Fin n, StronglyMeasurable[𝓕 i] (D2 i))
