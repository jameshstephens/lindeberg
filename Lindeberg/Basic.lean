    (hd2_ae : forall i : Fin n, AEStronglyMeasurable (D2 i) μ)
    (hind1 : forall i : Fin n, IndepFun (fun ω => Y ω i) (D1 i) μ)
    (hind2 : forall i : Fin n, IndepFun (fun ω => (Y ω i) ^ 2) (D2 i) μ)
