    (hD1 : forall i : Fin n, ∀ᵐ ω ∂μ, |D1 i ω| <= L1)
    (hD2 : forall i : Fin n, ∀ᵐ ω ∂μ, |D2 i ω| <= L2)
    (hInt1 : forall i : Fin n,
      Integrable (fun ω =>
        |(condExp (𝓕 i) μ (fun ω => X ω i)) ω - ∫ ν, Y ν i ∂μ|) μ)
    (hInt2 : forall i : Fin n,
      Integrable (fun ω =>
        |(condExp (𝓕 i) μ (fun ω => (X ω i) ^ 2)) ω -
