    (hconst2 : forall i : Fin n,
      Integrable (fun ω => (∫ ν, (Y ν i) ^ 2 ∂μ) * D2 i ω) μ)
    (hrx : forall i : Fin n,
      ∀ᵐ ω ∂μ,
        |coordinateTaylorRemainder f (lindebergFrozen X Y i ω) i
          (D1 i ω) (D2 i ω) (X ω i)| <=
