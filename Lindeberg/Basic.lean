      ∀ᵐ ω ∂μ, |RX i ω| <= (1 / 6 : Real) * L3 * |X ω i| ^ 3)
    (hry : forall i : Fin n,
      ∀ᵐ ω ∂μ, |RY i ω| <= (1 / 6 : Real) * L3 * |Y ω i| ^ 3)
    (h_taylor : forall i : Fin n,
